<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <Playwright>
    <!-- Browser engine: chromium | firefox | webkit -->
    <BrowserName>chromium</BrowserName>

    <LaunchOptions>
      <!-- Set to true for CI/headless environments, false for local debugging -->
      <Headless>false</Headless>
      <!-- Slow down operations by the specified milliseconds (useful for debugging) -->
      <SlowMo>0</SlowMo>
    </LaunchOptions>

    <!-- Default timeout for Expect assertions (ms) -->
    <ExpectTimeout>15000</ExpectTimeout>
  </Playwright>

  <!-- NUnit adapter settings -->
  <NUnit>
    <!-- Number of test workers (parallel execution). Set to 1 for sequential. -->
    <NumberOfTestWorkers>1</NumberOfTestWorkers>
  </NUnit>
</RunSettings>
