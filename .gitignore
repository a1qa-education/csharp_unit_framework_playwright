## Consolidated .NET and Visual Studio .gitignore
## Combining standard .NET build results with thorough IDE-specific entries.

# =========================
# Build results
# =========================
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# =========================
# Visual Studio Specific
# =========================
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# (Optional) If you want to track shared launch settings but hide user ones:
# !.vs/launchSettings.json

# Visual Studio Code
.vscode/
# (Optional) Uncomment if you want to ignore the whole folder. 
# Modern .NET teams often keep launch.json/tasks.json, so specific ignores are better:
.vscode/extensions.json
.vscode/.history/

# =========================
# .NET / ASP.NET Tools
# =========================
project.lock.json
project.fragment.lock.json
artifacts/
ScaffoldingReadMe.txt
.env

# NuGet Packages
*.nupkg
*.snupkg
# (Optional) Local packages folder
# packages/

# =========================
# Testing and Coverage
# =========================
CodeCoverage/
*.binlog
[Tt]est[Rr]esult*/
[Bb]build[Ll]og.*

# NUnit / MSTest
*.VisualState.xml
TestResult.xml
nunit-*.xml

# =========================
# OS / Others
# =========================
# Backup and temporary files
~$*
*~
*.tmp
*.bak
*.swp

# macOS
.DS_Store